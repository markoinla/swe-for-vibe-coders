---
import BaseLayout from './BaseLayout.astro';
import { moduleBySlug } from '../data/modules';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'lessons'>;
  prev?: { slug: string; title: string } | null;
  next?: { slug: string; title: string } | null;
  lessonIndex: number;
  lessonCount: number;
}

const { entry, prev, next, lessonIndex, lessonCount } = Astro.props;
const { title, description, module: moduleSlug, minutes } = entry.data;
const mod = moduleBySlug(moduleSlug);
---

<BaseLayout title={title} description={description}>
  <article class="container prose py-10">
    <nav class="flex gap-2 text-[0.9rem] text-muted">
      <a href="/#curriculum" class="text-muted no-underline hover:text-body">Curriculum</a>
      <span aria-hidden="true">/</span>
      {mod && (
        <a href={`/modules/${mod.slug}`} class="text-muted no-underline hover:text-body">
          {mod.emoji} {mod.title}
        </a>
      )}
    </nav>

    <div class="mt-5 flex gap-2.5 text-[0.85rem] uppercase tracking-wider text-muted">
      <span>Lesson {lessonIndex} of {lessonCount}</span>
      <span aria-hidden="true">·</span>
      <span>{minutes} min</span>
    </div>

    <h1 class="mt-2 text-[2.4rem] max-sm:text-[1.9rem]">{title}</h1>
    <p class="mt-3 text-[1.2rem] text-muted">{description}</p>

    <hr />

    <slot />

    <nav class="mt-16 grid grid-cols-2 gap-4 border-t border-line pt-6 max-sm:grid-cols-1">
      {prev ? (
        <a class="group flex flex-col gap-1 rounded-card border border-line bg-elevated px-[18px] py-3.5 no-underline transition-colors hover:border-accent" href={`/lessons/${prev.slug}`}>
          <span class="text-[0.8rem] font-semibold text-accent">← Previous</span>
          <span class="font-semibold text-body">{prev.title}</span>
        </a>
      ) : <span />}
      {next ? (
        <a class="flex flex-col gap-1 rounded-card border border-line bg-elevated px-[18px] py-3.5 text-right no-underline transition-colors hover:border-accent" href={`/lessons/${next.slug}`}>
          <span class="text-[0.8rem] font-semibold text-accent">Next →</span>
          <span class="font-semibold text-body">{next.title}</span>
        </a>
      ) : (
        <a class="flex flex-col gap-1 rounded-card border border-line bg-elevated px-[18px] py-3.5 text-right no-underline transition-colors hover:border-accent" href="/#curriculum">
          <span class="text-[0.8rem] font-semibold text-accent">Done →</span>
          <span class="font-semibold text-body">Back to curriculum</span>
        </a>
      )}
    </nav>
  </article>
</BaseLayout>
