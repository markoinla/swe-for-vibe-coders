---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'An interactive course teaching software engineering basics to vibe coders.' } = Astro.props;
const fullTitle = title === 'SWE for Vibe Coders' ? title : `${title} · SWE for Vibe Coders`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body>
    <header class="site-header">
      <div class="container bar">
        <a href="/" class="brand">SWE<span class="dot">.</span>for vibe coders</a>
        <nav class="nav-links">
          <a href="/#curriculum">Curriculum</a>
          <a href="/about">About</a>
          <a href="https://github.com/markoinla/swe-for-vibe-coders" target="_blank" rel="noopener">GitHub</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>
          Built with <a href="https://astro.build" target="_blank" rel="noopener">Astro</a>,
          hosted on Cloudflare. A hands-on introduction to software engineering for
          people who got here by vibe coding.
        </p>
      </div>
    </footer>
  </body>
</html>
