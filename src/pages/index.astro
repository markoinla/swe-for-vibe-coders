---
import BaseLayout from '../layouts/BaseLayout.astro';
import { modules } from '../data/modules';
import { getCollection } from 'astro:content';

const lessons = await getCollection('lessons', ({ data }) => data.published);
const lessonCount = (slug: string) =>
  lessons.filter((l) => l.data.module === slug).length;

// First lesson of the first available module, for the primary CTA.
const firstModule = modules.find((m) => m.status === 'available');
const firstLesson = firstModule
  ? lessons
      .filter((l) => l.data.module === firstModule.slug)
      .sort((a, b) => a.data.order - b.data.order)[0]
  : undefined;
---

<BaseLayout title="SWE for Vibe Coders">
  <section class="hero">
    <div class="container">
      <p class="eyebrow">For people who ship with AI</p>
      <h1>Software engineering<br />for vibe coders.</h1>
      <p class="sub">
        You can already build things. This is the stuff the AI never sat you down and
        explained — version control, testing, not leaking your API keys — taught in
        short, interactive lessons you actually do, not just read.
      </p>
      <div class="hero-cta">
        {firstLesson && (
          <a class="btn" href={`/lessons/${firstLesson.id}`}>Start with {firstModule?.title} →</a>
        )}
        <a class="btn secondary" href="#curriculum">See the curriculum</a>
      </div>
    </div>
  </section>

  <section class="pitch container">
    <div class="pitch-grid">
      <div class="pitch-card">
        <span class="pitch-icon">🧠</span>
        <h3>Concepts that click</h3>
        <p>Plain-language explanations with real examples — no CS-degree jargon, no gatekeeping.</p>
      </div>
      <div class="pitch-card">
        <span class="pitch-icon">🎯</span>
        <h3>Check yourself</h3>
        <p>Quick interactive questions after each idea so you know it landed before moving on.</p>
      </div>
      <div class="pitch-card">
        <span class="pitch-icon">🛠️</span>
        <h3>Do it for real</h3>
        <p>Each module ends with a hands-on exercise in an actual repo — the tools you already use.</p>
      </div>
    </div>
  </section>

  <section id="curriculum" class="container wide curriculum">
    <div class="section-head">
      <h2>The curriculum</h2>
      <p>Seven modules, built to be taken in order. Start anywhere, but version control first pays off everywhere else.</p>
    </div>
    <ol class="module-list">
      {modules.map((mod, i) => {
        const count = lessonCount(mod.slug);
        const available = mod.status === 'available';
        const Tag = available ? 'a' : 'div';
        return (
          <li>
            <Tag
              class={`module-card ${available ? '' : 'locked'}`}
              {...(available ? { href: `/modules/${mod.slug}` } : {})}
            >
              <span class="module-num">{String(i + 1).padStart(2, '0')}</span>
              <span class="module-emoji">{mod.emoji}</span>
              <div class="module-text">
                <div class="module-title-row">
                  <h3>{mod.title}</h3>
                  {available ? (
                    <span class="pill available">{count} {count === 1 ? 'lesson' : 'lessons'}</span>
                  ) : (
                    <span class="pill soon">Coming soon</span>
                  )}
                </div>
                <p class="module-tagline">{mod.tagline}</p>
                <p class="module-desc">{mod.description}</p>
              </div>
            </Tag>
          </li>
        );
      })}
    </ol>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 72px 0 48px;
    text-align: center;
  }
  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--accent);
    margin: 0 0 16px;
  }
  .hero h1 {
    font-size: clamp(2.4rem, 6vw, 3.6rem);
    margin: 0;
    letter-spacing: -0.035em;
  }
  .hero .sub {
    max-width: 620px;
    margin: 22px auto 0;
    font-size: 1.18rem;
    color: var(--text-muted);
  }
  .hero-cta {
    margin-top: 32px;
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .pitch { padding: 24px 0 8px; }
  .pitch-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }
  .pitch-card {
    padding: 22px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-elevated);
  }
  .pitch-icon { font-size: 1.6rem; }
  .pitch-card h3 { margin: 12px 0 6px; font-size: 1.1rem; }
  .pitch-card p { margin: 0; color: var(--text-muted); font-size: 0.96rem; }

  .curriculum { padding: 64px 0 20px; }
  .section-head { text-align: center; max-width: 620px; margin: 0 auto 36px; }
  .section-head h2 { font-size: 2rem; margin: 0; }
  .section-head p { color: var(--text-muted); margin: 12px 0 0; }

  .module-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .module-card {
    display: flex;
    align-items: flex-start;
    gap: 18px;
    padding: 22px 24px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-elevated);
    color: var(--text);
    transition: border-color 0.15s ease, transform 0.08s ease, box-shadow 0.15s ease;
  }
  a.module-card:hover {
    border-color: var(--accent);
    text-decoration: none;
    box-shadow: var(--shadow);
    transform: translateY(-1px);
  }
  .module-card.locked { opacity: 0.72; }
  .module-num {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--text-muted);
    padding-top: 4px;
  }
  .module-emoji { font-size: 1.8rem; line-height: 1; }
  .module-text { flex: 1; }
  .module-title-row {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }
  .module-title-row h3 { margin: 0; font-size: 1.25rem; }
  .pill {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 3px 10px;
    border-radius: 999px;
  }
  .pill.available { background: var(--accent-soft); color: var(--accent); }
  .pill.soon { background: var(--bg-sunken); color: var(--text-muted); }
  .module-tagline { margin: 6px 0 0; font-weight: 600; color: var(--text); }
  .module-desc { margin: 6px 0 0; color: var(--text-muted); font-size: 0.96rem; }

  @media (max-width: 720px) {
    .pitch-grid { grid-template-columns: 1fr; }
    .module-emoji { display: none; }
  }
</style>
