---
import LessonLayout from '../../layouts/LessonLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const lessons = (await getCollection('lessons', ({ data }) => data.published));

  // Group by module and sort, so we can compute prev/next within a module.
  const byModule = new Map<string, typeof lessons>();
  for (const l of lessons) {
    const arr = byModule.get(l.data.module) ?? [];
    arr.push(l);
    byModule.set(l.data.module, arr);
  }
  for (const arr of byModule.values()) {
    arr.sort((a, b) => a.data.order - b.data.order);
  }

  return lessons.map((entry) => {
    const siblings = byModule.get(entry.data.module)!;
    const idx = siblings.findIndex((s) => s.id === entry.id);
    const prev = idx > 0 ? siblings[idx - 1] : null;
    const next = idx < siblings.length - 1 ? siblings[idx + 1] : null;
    return {
      params: { slug: entry.id },
      props: {
        entry,
        lessonIndex: idx + 1,
        lessonCount: siblings.length,
        prev: prev ? { slug: prev.id, title: prev.data.title } : null,
        next: next ? { slug: next.id, title: next.data.title } : null,
      },
    };
  });
}

const { entry, lessonIndex, lessonCount, prev, next } = Astro.props;
const { Content } = await render(entry);
---

<LessonLayout
  entry={entry}
  lessonIndex={lessonIndex}
  lessonCount={lessonCount}
  prev={prev}
  next={next}
>
  <Content />
</LessonLayout>
