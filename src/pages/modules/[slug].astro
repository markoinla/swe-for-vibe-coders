---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { modules, moduleBySlug } from '../../data/modules';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  return modules
    .filter((m) => m.status === 'available')
    .map((m) => ({ params: { slug: m.slug } }));
}

const { slug } = Astro.params;
const mod = moduleBySlug(slug!)!;

const lessons = (await getCollection('lessons', ({ data }) => data.published))
  .filter((l) => l.data.module === slug)
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title={mod.title} description={mod.description}>
  <section class="container mx-auto max-w-[620px] pb-2 pt-12 text-center">
    <a class="mb-5 inline-block text-[0.9rem] text-muted no-underline hover:text-body" href="/#curriculum">← All modules</a>
    <div class="text-[3rem]">{mod.emoji}</div>
    <h1 class="mt-2 text-[2.4rem]">{mod.title}</h1>
    <p class="mt-2 font-semibold">{mod.tagline}</p>
    <p class="mt-3 text-muted">{mod.description}</p>
  </section>

  <section class="container max-w-[720px] pb-10 pt-8">
    <ol class="m-0 flex list-none flex-col gap-2.5 p-0">
      {lessons.map((lesson, i) => (
        <li>
          <a
            href={`/lessons/${lesson.id}`}
            class="flex items-center gap-4 rounded-card border border-line bg-elevated px-5 py-4 text-body no-underline transition-colors hover:border-accent"
          >
            <span class="grid h-8 w-8 shrink-0 place-items-center rounded-full bg-accent-soft font-bold text-accent">
              {i + 1}
            </span>
            <span class="flex flex-1 flex-col">
              <span class="font-semibold">{lesson.data.title}</span>
              <span class="text-[0.9rem] text-muted">{lesson.data.description}</span>
            </span>
            <span class="shrink-0 text-[0.82rem] tabular-nums text-muted">{lesson.data.minutes} min</span>
          </a>
        </li>
      ))}
    </ol>
    {lessons.length === 0 && <p class="text-muted">Lessons for this module are being written.</p>}
  </section>
</BaseLayout>
