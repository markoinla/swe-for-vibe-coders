---
interface Props {
  type?: 'info' | 'tip' | 'warning' | 'danger';
  title?: string;
}
const { type = 'info', title } = Astro.props;
const icons = { info: 'ℹ️', tip: '💡', warning: '⚠️', danger: '🛑' };
const defaultTitles = { info: 'Note', tip: 'Tip', warning: 'Watch out', danger: 'Danger' };
// border-left colour + background per type
const styles = {
  info: 'border-l-accent bg-elevated',
  tip: 'border-l-success bg-success-soft',
  warning: 'border-l-warning bg-warning-soft',
  danger: 'border-l-danger bg-danger-soft',
};
---
<aside class={`my-7 rounded-card border border-line border-l-4 px-[18px] py-4 ${styles[type]}`}>
  <div class="flex items-center gap-2 text-[0.95rem] font-bold">
    <span aria-hidden="true">{icons[type]}</span>
    <span>{title ?? defaultTitles[type]}</span>
  </div>
  <div class="mt-1.5 text-[0.98rem] text-body [&>:first-child]:mt-0 [&>:last-child]:mb-0">
    <slot />
  </div>
</aside>
