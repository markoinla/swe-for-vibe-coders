---
// A "go do it for real" callout that sends the learner into an actual editor/repo.
// This is the hands-on backbone of the course — reading about git is not the same
// as running it.
interface Props {
  title?: string;
}
const { title = 'Try it for real' } = Astro.props;
---
<section class="my-9 rounded-card border border-accent/30 bg-accent-soft px-6 py-[22px]">
  <div class="flex items-center gap-2.5">
    <span class="text-[1.3rem]" aria-hidden="true">🛠️</span>
    <h3 class="m-0 text-[1.15rem] text-body">{title}</h3>
  </div>
  <div class="mt-2.5 text-base [&>:first-child]:mt-0 [&>:last-child]:mb-0 [&_ol]:mt-2">
    <slot />
  </div>
</section>
